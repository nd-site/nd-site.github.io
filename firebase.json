{
  "hosting": {
    "site": "ndsite",
    "public": ".",
    "cleanUrls": true,
    "trailingSlash": true,
    "retainedBackups": 5,
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "package.json",
      "package-lock.json",
      "vite.config.ts",
      "tsconfig.json",
      "tsconfig.node.json",
      "capacitor.config.ts",
      "env.json",
      "push_secrets.ps1",
      "set_gemini_key.js",
      "functions/**",
      ".github/**",
      "_agent/**",
      "scan2word/**",
      "android/**",
      "ND_bot_LotusChat/**",
      "admin/**",
      "live_download/**",
      "src/**",
      "dist/**",
      "*.cjs",
      "*.ts",
      "**/*.exe",
      "**/*.cmd",
      "**/*.ps1",
      "**/*.sh",
      "**/*.bat",
      "**/*.dll",
      "**/*.so",
      "**/*.bin"
    ]
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ]
    }
  ]
}