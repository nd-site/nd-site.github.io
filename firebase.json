{
  "hosting": {
    "site": "ndsite",
    "public": ".",
    "cleanUrls": true,
    "trailingSlash": true,
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "package.json",
      "package-lock.json",
      "vite.config.ts",
      "tsconfig.json",
      "functions/**",
      ".github/**",
      "_agent/**",
      "*.cjs",
      "*.ts"
    ]
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ]
    }
  ]
}
