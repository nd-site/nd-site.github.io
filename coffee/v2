    <!-- Scripts -->
    <script>
        let loadedData = null;
        let chartInstance = null;
        
        // Đoạn API Key này sẽ được xử lý tự động thông qua quy trình Deploy GitHub Actions của bạn.
        // Bạn có thể setup quy trình tự động replace chuỗi rỗng dưới đây bằng API Key của bạn khi Build.
        const apiKey = ""; 

        // Initialize Icons
        function initIcons() {
            if (window.lucide) {
                lucide.createIcons();
            }
        }

        // Helper for currency formatting
        function formatVND(value) {
            return new Intl.NumberFormat('vi-VN').format(value) + " đ";
        }

        // Search in Table
        document.getElementById('table-search').addEventListener('input', function(e) {
            if (!loadedData) return;
            const query = e.target.value.toLowerCase().trim();
            const filtered = loadedData.danh_sach_gia.filter(item => 
                item.tinh.toLowerCase().includes(query) || 
                item.vung.toLowerCase().includes(query)
            );
            renderTable(filtered);
        });

        // Main UI Renderer
        function renderUI(data, timestamp) {
            // Hide skeleton, show real content
            document.getElementById('skeleton-container').classList.add('hidden');
            document.getElementById('real-content').classList.remove('hidden');

            // Set Extraction Time
            document.getElementById('extraction-time').innerText = `Trích xuất: ${timestamp}`;

            // Spotlight Lâm Đồng Setup
            const ldObj = data.danh_sach_gia.find(item => item.tinh.includes("Lâm Đồng"));
            if (ldObj) {
                document.getElementById('ld-price').innerText = formatVND(ldObj.gia);
                
                const changeVal = ldObj.thay_doi;
                const changeContainer = document.getElementById('ld-change-container');
                const changeText = document.getElementById('ld-change-text');
                
                if (changeVal > 0) {
                    changeContainer.className = "flex items-center text-xs font-bold text-emerald-600 bg-emerald-50 px-2.5 py-1 rounded-md w-max";
                    changeText.innerHTML = `<i data-lucide="trending-up" class="w-3.5 h-3.5 mr-0.5"></i> +${formatVND(changeVal)}/kg`;
                } else if (changeVal < 0) {
                    changeContainer.className = "flex items-center text-xs font-bold text-rose-600 bg-rose-50 px-2.5 py-1 rounded-md w-max";
                    changeText.innerHTML = `<i data-lucide="trending-down" class="w-3.5 h-3.5 mr-0.5"></i> ${formatVND(changeVal)}/kg`;
                } else {
                    changeContainer.className = "flex items-center text-xs font-bold text-stone-500 bg-stone-100 px-2.5 py-1 rounded-md w-max";
                    changeText.innerHTML = `<i data-lucide="minus" class="w-3.5 h-3.5 mr-0.5"></i> Không đổi`;
                }

                // Subregions for Lâm Đồng
                const vld = data.vung_lam_dong || { "dilinh": ldObj.gia - 100, "baoloc": ldObj.gia + 100, "lamha": ldObj.gia };
                document.getElementById('ld-dilinh').innerText = formatVND(vld.dilinh);
                document.getElementById('ld-baoloc').innerText = formatVND(vld.baoloc);
                document.getElementById('ld-lamha').innerText = formatVND(vld.lamha);
            }

            // Market Overview Card
            document.getElementById('market-overview').innerText = data.nhan_xet;
            document.getElementById('market-trend').innerText = data.xu_huong || "Chưa rõ";

            // Futures Market
            if (data.london) {
                document.getElementById('london-price').innerText = `${data.london.price} USD`;
                document.getElementById('london-change').innerText = data.london.change;
                document.getElementById('london-change').className = `text-[10px] font-bold px-1.5 py-0.5 rounded ${data.london.change.startsWith('+') ? 'bg-emerald-50 text-emerald-600' : 'bg-rose-50 text-rose-600'}`;
            }
            if (data.new_york) {
                document.getElementById('ny-price').innerText = `${data.new_york.price} Cents`;
                document.getElementById('ny-change').innerText = data.new_york.change;
                document.getElementById('ny-change').className = `text-[10px] font-bold px-1.5 py-0.5 rounded ${data.new_york.change.startsWith('+') ? 'bg-emerald-50 text-emerald-600' : 'bg-rose-50 text-rose-600'}`;
            }

            renderTable(data.danh_sach_gia);
            renderChart(data.danh_sach_gia);
            initIcons();
        }

        // Render Table Rows
        function renderTable(priceList) {
            const tableBody = document.getElementById('price-table-body');
            tableBody.innerHTML = '';

            priceList.forEach(item => {
                const isLamDong = item.tinh.includes("Lâm Đồng");
                const rowClass = isLamDong 
                    ? "bg-amber-50/40 hover:bg-amber-50/70 font-semibold border-y border-amber-300/40" 
                    : "hover:bg-stone-50 border-b border-stone-100";

                const changeColor = item.thay_doi > 0 
                    ? "text-emerald-600 font-bold" 
                    : item.thay_doi < 0 
                        ? "text-rose-600 font-bold" 
                        : "text-stone-400";

                const changeSign = item.thay_doi > 0 ? "+" : "";

                tableBody.innerHTML += `
                    <tr class="${rowClass} transition-colors">
                        <td class="py-3 px-4 flex items-center space-x-1.5">
                            ${isLamDong ? '<span class="w-2 h-2 rounded-full bg-amber-600 animate-pulse"></span>' : ''}
                            <span class="${isLamDong ? 'text-amber-950 font-bold' : 'text-stone-900'}">${item.tinh}</span>
                        </td>
                        <td class="py-3 px-3 text-stone-400 text-[10px]">${item.vung}</td>
                        <td class="py-3 px-3 text-right font-bold ${isLamDong ? 'text-amber-900 text-sm' : 'text-stone-950'}">${formatVND(item.gia)}</td>
                        <td class="py-3 px-4 text-right text-[11px] ${changeColor}">
                            ${item.thay_doi !== 0 ? `${changeSign}${formatVND(item.thay_doi)}` : '0 đ'}
                        </td>
                    </tr>
                `;
            });
        }

        // Render Chart.js
        function renderChart(priceList) {
            const ctx = document.getElementById('comparisonChart').getContext('2d');
            if (chartInstance) {
                chartInstance.destroy();
            }

            const labels = priceList.map(item => item.tinh);
            const data = priceList.map(item => item.gia);
            const colors = priceList.map(item => item.tinh.includes("Lâm Đồng") ? '#d97706' : '#78350f');
            const hoverColors = priceList.map(item => item.tinh.includes("Lâm Đồng") ? '#f59e0b' : '#92400e');

            chartInstance = new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: labels,
                    datasets: [{
                        data: data,
                        backgroundColor: colors,
                        hoverBackgroundColor: hoverColors,
                        borderRadius: 6,
                        barThickness: 15
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false },
                        tooltip: {
                            callbacks: {
                                label: function(context) {
                                    return ` ${formatVND(context.parsed.y)}`;
                                }
                            }
                        }
                    },
                    scales: {
                        y: {
                            beginAtZero: false,
                            min: Math.min(...data) - 1000,
                            max: Math.max(...data) + 1000,
                            ticks: {
                                callback: value => value / 1000 + 'k',
                                font: { size: 9, family: 'Plus Jakarta Sans' }
                            },
                            grid: { color: '#f5f5f4' }
                        },
                        x: {
                            ticks: { font: { size: 9, family: 'Plus Jakarta Sans' } },
                            grid: { display: false }
                        }
                    }
                }
            });

            // Calculate Range
            const min = Math.min(...data);
            const max = Math.max(...data);
            document.getElementById('avg-volatility').innerText = formatVND(max - min);
        }

        // Fetch Live Prices with Exponential Backoff
        async function fetchLivePrices(retries = 5, delay = 1000) {
            // Sử dụng trực tiếp biến khóa tĩnh được nạp từ GitHub Actions / Env
            const endpoint = `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${apiKey}`;
            const sysPrompt = "Bạn là một hệ thống robot tự động thu thập và chuẩn hóa dữ liệu tài chính nông nghiệp Việt Nam dưới dạng JSON sạch.";
            
            const prompt = `Hãy truy cập trang web https://giacaphe.com/gia-ca-phe-noi-dia/ để lấy bảng giá cà phê nội địa mới nhất hôm nay. 
Trích xuất chi tiết giá của các tỉnh Tây Nguyên bao gồm: Lâm Đồng (lấy cả giá cụ thể của Bảo Lộc, Di Linh, Lâm Hà), Đắk Lắk, Gia Lai, Đắk Nông, Kon Tum, Đồng Nai.
Đồng thời lấy tỷ giá cà phê kỳ hạn mới nhất thế giới (Robusta London, Arabica New York).

Trả về định dạng JSON thuần khiết không kèm theo khối mã markdown hay bất kỳ từ ngữ thừa nào. Cấu trúc yêu cầu:
{
  "nhan_xet": "Nhận định thị trường ngắn gọn bằng tiếng Việt (2-3 câu). Nói về tình hình giá Lâm Đồng và xu hướng biến động.",
  "xu_huong": "Tăng nhẹ / Giảm nhẹ / Đi ngang / Biến động mạnh",
  "london": { "price": "Ví dụ: 4,120", "change": "Ví dụ: +1.2%" },
  "new_york": { "price": "Ví dụ: 235.45", "change": "Ví dụ: -0.5%" },
  "danh_sach_gia": [
    { "tinh": "Lâm Đồng", "vung": "Bảo Lộc, Di Linh, Lâm Hà", "gia": 97900, "thay_doi": 6100 },
    { "tinh": "Đắk Lắk", "vung": "Cư M'gar, Buôn Hồ", "gia": 99200, "thay_doi": 6000 },
    { "tinh": "Gia Lai", "vung": "Chư Prông, Pleiku", "gia": 98800, "thay_doi": 6100 },
    { "tinh": "Đắk Nông", "vung": "Gia Nghĩa, Đắk R'lấp", "gia": 99500, "thay_doi": 6200 },
    { "tinh": "Kon Tum", "vung": "Đắk Hà", "gia": 98500, "thay_doi": 6000 },
    { "tinh": "Đồng Nai", "vung": "Định Quán", "gia": 98000, "thay_doi": 5800 }
  ],
  "vung_lam_dong": {
    "dilinh": 97800,
    "baoloc": 98000,
    "lamha": 97900
  }
}
Lưu ý các giá trị trong trường 'gia', 'thay_doi' và 'vung_lam_dong' phải luôn là Kiểu Số Nguyên (Integer) sạch không chứa dấu chấm hay dấu phẩy phân tách.`;

            const payload = {
                contents: [{ parts: [{ text: prompt }] }],
                systemInstruction: { parts: [{ text: sysPrompt }] },
                tools: [{ "google_search": {} }],
                generationConfig: {
                    responseMimeType: "application/json"
                }
            };

            for (let i = 0; i < retries; i++) {
                try {
                    const response = await fetch(endpoint, {
                        method: "POST",
                        headers: { "Content-Type": "application/json" },
                        body: JSON.stringify(payload)
                    });

                    if (!response.ok) {
                        throw new Error(`HTTP ${response.status}`);
                    }

                    const result = await response.json();
                    let rawText = result.candidates?.[0]?.content?.parts?.[0]?.text;
                    
                    if (rawText) {
                        rawText = rawText.replace(/```json/g, "").replace(/```/g, "").trim();
                        return JSON.parse(rawText);
                    }
                    throw new Error("Không nhận được dữ liệu hợp lệ.");
                } catch (err) {
                    if (i === retries - 1) throw err;
                    await new Promise(resolve => setTimeout(resolve, delay * Math.pow(2, i)));
                }
            }
        }

        // Action Trigger
        async function loadAndSyncData() {
            const btn = document.getElementById('btn-refresh');
            const icon = document.getElementById('refresh-icon');
            const errorBox = document.getElementById('error-box');
            const liveIndicator = document.getElementById('live-indicator');

            btn.disabled = true;
            icon.classList.add('animate-spin');
            errorBox.classList.add('hidden');
            liveIndicator.innerHTML = '<span class="w-1.5 h-1.5 rounded-full bg-amber-500 animate-pulse mr-1.5"></span>Trích xuất...';

            document.getElementById('skeleton-container').classList.remove('hidden');
            document.getElementById('real-content').classList.add('hidden');

            try {
                const data = await fetchLivePrices();
                if (data && data.danh_sach_gia) {
                    loadedData = data;
                    
                    const now = new Date();
                    const formattedTime = `${now.toLocaleTimeString('vi-VN')} ngày ${now.toLocaleDateString('vi-VN')}`;

                    renderUI(data, formattedTime);
                    liveIndicator.innerHTML = '<span class="w-1.5 h-1.5 rounded-full bg-emerald-500 mr-1.5"></span>Đồng bộ thành công';
                    liveIndicator.className = "inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold bg-emerald-50 text-emerald-700 border border-emerald-200/60";
                } else {
                    throw new Error("Định dạng dữ liệu trích xuất sai cấu trúc.");
                }
            } catch (err) {
                console.error("Lỗi đồng bộ:", err);
                errorBox.classList.remove('hidden');
                document.getElementById('error-message').innerText = `Lỗi: ${err.message}. Nhấn nút "Tải lại dữ liệu" để thử lại.`;
                liveIndicator.innerHTML = '<span class="w-1.5 h-1.5 rounded-full bg-red-500 mr-1.5"></span>Lỗi đồng bộ';
                liveIndicator.className = "inline-flex items-center px-2 py-0.5 rounded-full text-[10px] font-bold bg-red-50 text-red-700 border border-red-200/60";
            } finally {
                btn.disabled = false;
                icon.classList.remove('animate-spin');
            }
        }

        document.getElementById('btn-refresh').addEventListener('click', loadAndSyncData);

        window.onload = function() {
            initIcons();
            loadAndSyncData();
        };
    </script>
</body>
